<UserControl x:Class="UnityProjectAnalyzer.Views.Pages.ScriptsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="PageResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Margin="20" Background="#161b22" BorderBrush="#30363d" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="#bc8cff" VerticalAlignment="Center"/>
                        <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0">
                            <Run Text="스크립트 코드 분석"/>
                            <Run Text=" — 행 또는 [✦ AI 리뷰] 클릭 시 Gemini 리뷰" Foreground="#8b949e" FontSize="10"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Foreground="#8b949e" FontSize="10" VerticalAlignment="Center">
                        <Run Text="총 "/>
                        <Run Text="{Binding ScriptCount}" Foreground="#c9d1d9" FontWeight="SemiBold"/>
                        <Run Text="개"/>
                    </TextBlock>
                </Grid>
            </Border>

            <Border Grid.Row="1" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding ScriptFilter, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,5" FontSize="10"/>
                    <CheckBox Grid.Column="1" Content="진단 있는 것만"
                              IsChecked="{Binding ShowOnlyWithFindings}"
                              Margin="12,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Scripts}" Padding="8,6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Padding="8,8" HorizontalContentAlignment="Stretch"
                                                ToolTip="{Binding RelativePath}"
                                                Command="{Binding DataContext.ReviewScriptCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" CornerRadius="3" Padding="6,2" Margin="0,0,10,0"
                                                                    Background="{Binding Severity, Converter={StaticResource SevToBrush}}"
                                                                    Opacity="0.2" MinWidth="36">
                                                                <TextBlock Text="{Binding Severity}" FontSize="9" FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           Foreground="{Binding Severity, Converter={StaticResource SevToBrush}}"/>
                                                            </Border>
                                                            <StackPanel Grid.Column="1">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                                    <TextBlock Text=".cs" Foreground="#8b949e" FontSize="11"/>
                                                                    <TextBlock Text=" · " Foreground="#8b949e" FontSize="10" Margin="4,0"/>
                                                                    <TextBlock Text="{Binding SubtitleText}" Foreground="#8b949e" FontSize="10"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding RelativePath}" Foreground="#8b949e" FontSize="9"
                                                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                                <TextBlock Text="{Binding FindingsSummary}" Foreground="#c9d1d9" FontSize="10"
                                                                           TextWrapping="Wrap" Margin="0,4,0,0"
                                                                           Visibility="{Binding HasFindings, Converter={StaticResource BoolToVis}}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#21262d"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Grid.Column="1" Content="📄" Style="{StaticResource ToolBtn}"
                                                Padding="8,4" Margin="4,6" FontSize="11"
                                                ToolTip="에디터로 열기"
                                                Command="{Binding DataContext.OpenScriptFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Grid.Column="2" Content="✦ AI 리뷰" Style="{StaticResource ToolBtn}"
                                                Padding="10,4" Margin="4,6,8,6" FontSize="10"
                                                Command="{Binding DataContext.ReviewScriptCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="프로젝트를 분석하면 표시됩니다"
                           Foreground="#8b949e" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasScripts, Converter={StaticResource InvBoolToVis}}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
