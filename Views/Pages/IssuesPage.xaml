<UserControl x:Class="UnityProjectAnalyzer.Views.Pages.IssuesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="PageResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Margin="20" Background="#161b22" BorderBrush="#30363d" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="14,12">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Fill="#f85149" VerticalAlignment="Center"/>
                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0">
                        <Run Text="감지된 이슈"/>
                        <Run Text=" — 클릭하면 Gemini AI가 분석" Foreground="#8b949e" FontSize="10"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Issues}" Padding="16,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                        HorizontalContentAlignment="Stretch"
                                        Command="{Binding DataContext.AnalyzeIssueCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Padding="10,12" Background="Transparent"
                                                    BorderBrush="#30363d" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="3" Padding="6,2" Margin="0,0,10,0"
                                                            Background="{Binding Severity, Converter={StaticResource SevToBrush}}"
                                                            Opacity="0.2">
                                                        <TextBlock Text="{Binding Severity}" FontSize="9" FontWeight="Bold"
                                                                   Foreground="{Binding Severity, Converter={StaticResource SevToBrush}}"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Message}" Foreground="#c9d1d9"
                                                                   FontSize="11" TextWrapping="Wrap"/>
                                                        <TextBlock Foreground="#8b949e" FontSize="9" Margin="0,3,0,0">
                                                            <Run Text="{Binding Source}"/>
                                                            <Run Text=" · "/>
                                                            <Run Text="{Binding TimeAgo}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" Background="#1f2937" CornerRadius="3"
                                                            Padding="6,2" Visibility="{Binding HasAiSolution, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="✦ AI 분석" FontSize="9" Foreground="#58a6ff"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#21262d"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="감지된 이슈가 없습니다 — 깨끗해요 ✨"
                           Foreground="#8b949e" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasIssues, Converter={StaticResource InvBoolToVis}}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
