<Window x:Class="UnityProjectAnalyzer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UnityProjectAnalyzer.ViewModels"
        xmlns:conv="clr-namespace:UnityProjectAnalyzer.Converters"
        xmlns:pages="clr-namespace:UnityProjectAnalyzer.Views.Pages"
        Title="Unity Project Analyzer"
        Height="820" Width="1440"
        Background="#0d1117"
        FontFamily="Cascadia Mono, Consolas, Malgun Gothic, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:SeverityToBrushConverter x:Key="SevToBrush"/>
        <conv:BadgeStyleToBrushConverter x:Key="BadgeStyleToBrush"/>
        <conv:RoleToAlignmentConverter x:Key="RoleToAlign"/>
        <conv:RoleToBackgroundConverter x:Key="RoleToBg"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InvertBoolConverter x:Key="InvertBool"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== TITLE BAR ===== -->
        <Border Grid.Row="0" Background="#010409" BorderBrush="#30363d" BorderThickness="0,0,0,1" Height="40">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Path Data="M 0,18 L 9,0 L 18,18 Z" Fill="#58a6ff" Width="18" Height="18" Stretch="Uniform"/>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold">
                        <Run Text="Unity Project " Foreground="White"/>
                        <Run Text="Analyzer" Foreground="#58a6ff"/>
                        <Run Text=" v1.2" Foreground="#8b949e" FontSize="10"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== MAIN AREA ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- ===== SIDEBAR ===== -->
            <Border Grid.Column="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <!-- 프로젝트 카드 -->
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="현재 프로젝트" Foreground="#8b949e" FontSize="9"
                                   FontWeight="SemiBold" Margin="16,16,16,8"/>

                        <Border Background="#21262d" BorderBrush="#6e7681" BorderThickness="1"
                                CornerRadius="8" Margin="12,0,12,16" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{Binding ProjectName}" Foreground="White"
                                           FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Foreground="#8b949e" FontSize="10" Margin="0,4,0,0">
                                    <Run Text="Unity "/>
                                    <Run Text="{Binding UnityVersion}"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Ellipse Width="5" Height="5" Fill="#58a6ff" VerticalAlignment="Center"/>
                                    <TextBlock Text="분석 가능" Foreground="#58a6ff" FontSize="9" Margin="4,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="메뉴" Foreground="#8b949e" FontSize="9"
                                   FontWeight="SemiBold" Margin="16,0,16,4"/>
                    </StackPanel>

                    <!-- 푸터 (API 키 인디케이터) -->
                    <Border DockPanel.Dock="Bottom" BorderBrush="#30363d" BorderThickness="0,1,0,0"
                            Padding="16,10" Margin="0,8,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#f85149"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasApiKey}" Value="True">
                                                    <Setter Property="Fill" Value="#58a6ff"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Gemini" Foreground="#c9d1d9" FontSize="10" Margin="6,0,0,0"/>
                                <TextBlock Text="{Binding GeminiModel}" Foreground="#8b949e" FontSize="9" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Foreground="#8b949e" FontSize="9" Margin="0,4,0,0"
                                       Text="API 키 설정은 [설정] 페이지에서"/>
                        </StackPanel>
                    </Border>

                    <!-- nav 리스트 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding NavItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource NavBtn}"
                                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Page}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="13"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                       FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <Border Grid.Column="2" CornerRadius="10"
                                                    Background="{Binding BadgeStyle, Converter={StaticResource BadgeStyleToBrush}}"
                                                    Padding="6,1" Margin="0,0,2,0"
                                                    Visibility="{Binding HasBadge, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding Badge}" Foreground="White"
                                                           FontSize="9" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ===== CENTER (TOOLBAR + PAGES) ===== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TOOLBAR -->
                <Border Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="20,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentPageTitle}" Foreground="White"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Rectangle Width="1" Height="20" Fill="#30363d" Margin="14,0"/>
                            <Border Background="#21262d" BorderBrush="#30363d" BorderThickness="1"
                                    CornerRadius="6" Padding="10,5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📂 " Foreground="#8b949e" FontSize="10"/>
                                    <TextBlock Text="{Binding ProjectPath}" Foreground="#3fb950" FontSize="10"
                                               TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="📁 프로젝트 열기" Style="{StaticResource ToolBtn}"
                                    Command="{Binding OpenProjectCommand}" Margin="0,0,8,0"/>
                            <Button Content="▶ 재분석" Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding AnalyzeCommand}"
                                    IsEnabled="{Binding IsAnalyzing, Converter={StaticResource InvertBool}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- PAGE CONTAINER -->
                <Grid Grid.Row="1">
                    <pages:DashboardPage    Visibility="{Binding IsDashboard,     Converter={StaticResource BoolToVis}}"/>
                    <pages:AssetsPage       Visibility="{Binding IsAssetsPage,    Converter={StaticResource BoolToVis}}"/>
                    <pages:IssuesPage       Visibility="{Binding IsIssuesPage,    Converter={StaticResource BoolToVis}}"/>
                    <pages:ScriptsPage      Visibility="{Binding IsScriptsPage,   Converter={StaticResource BoolToVis}}"/>
                    <pages:DependencyPage   Visibility="{Binding IsDependencyPage,Converter={StaticResource BoolToVis}}"/>
                    <pages:ImportSettingsPage Visibility="{Binding IsImportSettingsPage,Converter={StaticResource BoolToVis}}"/>
                    <pages:BuildLogPage     Visibility="{Binding IsBuildLogPage,  Converter={StaticResource BoolToVis}}"/>
                    <pages:GitPage          Visibility="{Binding IsGitPage,       Converter={StaticResource BoolToVis}}"/>
                    <pages:SettingsPage     Visibility="{Binding IsSettingsPage,  Converter={StaticResource BoolToVis}}"/>
                </Grid>
            </Grid>

            <!-- ===== RIGHT PANEL (AI 채팅 — 모든 페이지에서 항상) ===== -->
            <Border Grid.Column="2" Background="#161b22" BorderBrush="#30363d" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="✦ AI 어시스턴트 (Gemini)" Foreground="#8b949e"
                                       FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="🗑 비우기" Style="{StaticResource ToolBtn}"
                                    Command="{Binding ClearChatCommand}" Padding="8,3" FontSize="9"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="ChatScroll" Padding="14,10">
                        <ItemsControl ItemsSource="{Binding ChatMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Role, Converter={StaticResource RoleToBg}}"
                                            BorderBrush="#30363d" BorderThickness="1"
                                            CornerRadius="8" Padding="10,8" Margin="0,5"
                                            MaxWidth="280"
                                            HorizontalAlignment="{Binding Role, Converter={StaticResource RoleToAlign}}">
                                        <TextBlock Text="{Binding Content}" Foreground="#c9d1d9"
                                                   FontSize="11" TextWrapping="Wrap" LineHeight="17"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="ChatInput_KeyDown"
                                     IsEnabled="{Binding IsChatting, Converter={StaticResource InvertBool}}"/>
                            <Button Grid.Column="1" Content="↑" Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding SendChatCommand}" Margin="6,0,0,0" Width="36" Padding="0"
                                    IsEnabled="{Binding IsChatting, Converter={StaticResource InvertBool}}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="2" Background="#010409" BorderBrush="#30363d" BorderThickness="0,1,0,0" Height="26">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="#58a6ff" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#c9d1d9" FontSize="10" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                    <TextBlock Foreground="#8b949e" FontSize="10">
                        <Run Text="에셋 "/>
                        <Run Text="{Binding TotalAssetCount}" Foreground="#c9d1d9"/>
                        <Run Text="  ·  "/>
                        <Run Text="{Binding TotalSizeText}" Foreground="#c9d1d9"/>
                        <Run Text="  ·  이슈 "/>
                        <Run Text="{Binding IssueCount}" Foreground="#c9d1d9"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
